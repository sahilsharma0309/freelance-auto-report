# Copy this file to .env and fill in your real key. NEVER commit .env.
#
# Get a free API key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# LiteLLM model string (provider/model). Any Groq-hosted model works.
# See https://console.groq.com/docs/models for the current list.
LLM_MODEL=groq/llama-3.3-70b-versatile

# Optional - only needed for scripts/weekly_report.py --to (emailed reports).
# For Gmail create an App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
